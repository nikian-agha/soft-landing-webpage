---
import '../styles/card-stack.css';
---

<!-- Scroll track: opening copy → card animation → end line -->
<section id="top" class="card-stack-hero relative w-full" aria-label="Hero">
  <div
    class="card-stack-hero__copy pointer-events-none relative z-20 mx-auto flex min-h-[100svh] max-w-5xl flex-col items-center justify-center px-5 py-20 text-center text-ink sm:px-8"
  >
    <h1 id="hero-start-copy" class="text-6xl leading-[0.98] sm:text-6xl">
      Finding your next home<br />
      is stressful
    </h1>
  </div>

  <div class="card-stack-hero__pin" id="hero-pin">
    <div
      class="card-stack-hero__end-copy pointer-events-none mx-auto max-w-5xl px-5 text-center text-ink sm:px-8"
      id="hero-end-copy"
    >
      <h1 class="text-5xl leading-[0.98] sm:text-6xl">
        Soft Landing uses AI to make it effortless
      </h1>
    </div>

    <div class="card-stack-hero__viewport" aria-hidden="true">
      <div class="card-stack-hero__plane" id="hero-card-plane"></div>

      <div class="card-stack-hero__match-labels" id="hero-match-labels" aria-hidden="true">
        <div class="card-stack-hero__match card-stack-hero__match--good">
          <span class="card-stack-hero__match-text">Ok match</span>
          <svg
            class="card-stack-hero__match-arrow"
            viewBox="0 0 160 112"
            fill="none"
            aria-hidden="true"
          >
            <path
              d="M150 20 C 92 4, 52 40, 46 102"
              stroke="currentColor"
              stroke-width="4"
              stroke-linecap="round"
              stroke-linejoin="round"
            ></path>
            <path
              d="M46 102 L 35 85 M 46 102 L 63 94"
              stroke="currentColor"
              stroke-width="4"
              stroke-linecap="round"
              stroke-linejoin="round"
            ></path>
          </svg>
        </div>

        <div class="card-stack-hero__match card-stack-hero__match--great">
          <svg
            class="card-stack-hero__match-arrow"
            viewBox="0 0 132 164"
            fill="none"
            aria-hidden="true"
          >
            <path
              d="M40 156 C 70 122, 56 64, 100 22"
              stroke="currentColor"
              stroke-width="4"
              stroke-linecap="round"
              stroke-linejoin="round"
            ></path>
            <path
              d="M100 22 L 84 26 M 100 22 L 98 41"
              stroke="currentColor"
              stroke-width="4"
              stroke-linecap="round"
              stroke-linejoin="round"
            ></path>
          </svg>
          <span class="card-stack-hero__match-text">Great match</span>
        </div>
      </div>

      <div class="card-stack-hero__hint" id="hero-card-hint">
        <span>Scroll</span>
        <svg
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
          aria-hidden="true"
        >
          <path d="M6 9l6 6 6-6"></path>
        </svg>
      </div>
    </div>

    <div class="card-stack-hero__stage" aria-hidden="true">
      <div
        class="pointer-events-none absolute inset-x-0 bottom-0 h-24 bg-gradient-to-b from-transparent to-white"
      ></div>
    </div>
  </div>
</section>

<script>
  import { initCardStackHero } from '../scripts/card-stack-hero';
  initCardStackHero();
</script>
