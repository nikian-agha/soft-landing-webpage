---
import Logo from './Logo.astro';
import Button from './Button.astro';

const year = new Date().getFullYear();
---

<!-- Final CTA band -->
<section id="start" class="scroll-mt-24 px-5 pb-8 sm:px-8">
  <div class="reveal mx-auto max-w-6xl overflow-hidden rounded-[var(--radius-card)] bg-ink px-6 py-16 text-center text-white sm:px-12 sm:py-20">
    <h2 class="mx-auto max-w-2xl text-4xl font-semibold leading-[1.05] sm:text-5xl">
      Your next home is out there. Let’s find it for you.
    </h2>
    <p class="mx-auto mt-5 max-w-lg text-lg text-white/70">
      Free during early access. Set your preferences in minutes and let Soft Landing take it from here.
    </p>
    <div class="mt-9 flex justify-center">
      <Button href="#top" variant="light">Start Your Search</Button>
    </div>
  </div>
</section>

<!-- Footer -->
<footer class="px-5 pb-12 pt-6 sm:px-8">
  <div class="mx-auto flex max-w-6xl flex-col items-center justify-between gap-6 border-t border-line pt-8 sm:flex-row">
    <Logo />
    <nav class="flex flex-wrap items-center justify-center gap-x-7 gap-y-2 text-base text-muted">
      <a href="#features" class="transition-colors hover:text-ink">Features</a>
      <a href="#faq" class="transition-colors hover:text-ink">FAQ</a>
      <a href="#" class="transition-colors hover:text-ink">Privacy</a>
      <a href="#" class="transition-colors hover:text-ink">Terms</a>
    </nav>
    <p class="text-sm text-muted">© {year} Soft Landing</p>
  </div>
</footer>
