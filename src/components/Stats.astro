---
import '@phosphor-icons/web/regular';

const subStats = [
  { icon: 'images', value: '24,000+', label: 'photos analysed' },
  { icon: 'article', value: '4,000+', label: 'descriptions read' },
  { icon: 'map-pin', value: '4,000+', label: 'locations evaluated' },
];
---

<section class="mx-auto max-w-6xl px-5 py-16 sm:px-8 sm:py-20">
  <div class="reveal rounded-[var(--radius-card)] bg-card px-6 py-10 text-center sm:px-12 sm:py-10">
    <p class="flex items-baseline justify-center gap-3">
      <span
        class="font-serif text-6xl font-medium tabular-nums leading-none sm:text-7xl md:text-[70px]"
        data-count-to="4730"
      >0</span>
    </p>
    <p class="mt-3 text-2xl font-normal sm:text-3xl">homes analysed to date</p>

    <div class="mx-auto mt-12 grid max-w-3xl grid-cols-2 gap-8 sm:grid-cols-3">
      {
        subStats.map((s, i) => (
          <div
            class:list={[
              'flex flex-col items-center gap-3',
              i === subStats.length - 1 && 'col-span-2 sm:col-span-1',
            ]}
          >
            <span class="flex h-12 w-12 items-center justify-center rounded-2xl bg-white text-ink shadow-[0_10px_28px_-16px_rgba(16,16,16,0.5)]">
              <i class={`ph ph-${s.icon} text-2xl`} aria-hidden="true"></i>
            </span>
            <span class="font-serif text-2xl font-semibold">{s.value}</span>
            <span class="text-base text-muted">{s.label}</span>
          </div>
        ))
      }
    </div>
  </div>
</section>

<script>
  const reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
  const els = document.querySelectorAll<HTMLElement>('[data-count-to]');

  const fmt = (n: number) => n.toLocaleString('en-GB');

  const run = (el: HTMLElement) => {
    const target = Number(el.dataset.countTo || '0');
    if (reduce) {
      el.textContent = fmt(target);
      return;
    }
    const duration = 1800;
    let start = 0;
    const tick = (t: number) => {
      if (!start) start = t;
      const p = Math.min((t - start) / duration, 1);
      // easeOutCubic
      const eased = 1 - Math.pow(1 - p, 3);
      el.textContent = fmt(Math.floor(eased * target));
      if (p < 1) requestAnimationFrame(tick);
      else el.textContent = fmt(target);
    };
    requestAnimationFrame(tick);
  };

  if (!('IntersectionObserver' in window)) {
    els.forEach(run);
  } else {
    const io = new IntersectionObserver(
      (entries) => {
        for (const e of entries) {
          if (e.isIntersecting) {
            run(e.target as HTMLElement);
            io.unobserve(e.target);
          }
        }
      },
      { threshold: 0.5 },
    );
    els.forEach((el) => io.observe(el));
  }
</script>
